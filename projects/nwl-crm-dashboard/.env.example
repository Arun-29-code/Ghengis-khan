# NextAuth
NEXTAUTH_SECRET=                      # generate: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000    # set to Vercel URL in production

# Dashboard credentials (one practice for MVP)
DASHBOARD_USERNAME=                   # e.g. premier
DASHBOARD_PASSWORD=                   # choose a strong password

# Practice identity
PRACTICE_NAME=                        # e.g. "Premier Medical Centre"
PRACTICE_ODS=                         # e.g. E84003

# Server-side storage — provision in Vercel dashboard:
#   Storage tab → Create → Blob → name it (e.g. nwl-csv-uploads)
# Vercel auto-injects this into deployments; pull locally with `vercel env pull`.
# Holds the latest CSV per practice/type; dashboard reads + parses on each load.
BLOB_READ_WRITE_TOKEN=
